# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/dams_db
DATABASE_USERNAME=dams_user
DATABASE_PASSWORD=dams_password

# JWT
# Generate a secure 256-bit base64 secret:
# echo -n "your-random-64-character-string" | base64
JWT_SECRET=bXlfc2VjcmV0X2tleV9mb3JfZGFtc19hcHBsaWNhdGlvbl8yMDI0X3Byb2R1Y3Rpb25fc2VjdXJl
JWT_EXPIRATION=86400000

# CORS
FRONTEND_URL=http://localhost:3000
